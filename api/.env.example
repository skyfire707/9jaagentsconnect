# 9jaAgentsConnect API Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=production

# Database - Railway provides this automatically
# DATABASE_URL=postgresql://user:pass@host:port/database

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Frontend URL (for CORS and email links)
CLIENT_URL=https://9jaagentsconnect.surge.sh

# Email Service (Resend - 3,000 emails/month free)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# Cloudinary (Image uploads - 25GB free)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional: Google Maps API (free tier available)
GOOGLE_MAPS_API_KEY=your-google-maps-key
